{
  "name": "draftiq",
  "private": true,
  "scripts": {
    "dev:web": "pnpm --filter @draftiq/web dev",
    "dev:api": "pnpm --filter @draftiq/api start:dev",
    "dev": "pnpm run dev:web & pnpm run dev:api",
    "build:web": "pnpm --filter @draftiq/web build",
    "build:api": "pnpm --filter @draftiq/api build",
    "lint": "pnpm -r lint"
  },
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  }
}