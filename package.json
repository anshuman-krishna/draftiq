{
  "name": "draftiq",
  "private": true,
  "scripts": {
    "dev": "pnpm run dev:web & pnpm run dev:api",
    "dev:web": "pnpm --filter @draftiq/web dev",
    "dev:api": "pnpm --filter @draftiq/api start:dev",
    "build": "pnpm run build:api && pnpm run build:web",
    "build:web": "pnpm --filter @draftiq/web build",
    "build:api": "pnpm --filter @draftiq/api build",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format",
    "db:migrate": "pnpm --filter @draftiq/api prisma:migrate",
    "db:seed": "pnpm --filter @draftiq/api prisma:seed"
  },
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "prettier": "^3.8.1"
  }
}